{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "env": {}
    },
    "blinky-serial": {
      "type": "stdio",
      "command": "ssh",
      "args": [
        "-o", "StrictHostKeyChecking=no",
        "blinkytime@blinkyhost.local",
        "cd /home/blinkytime/blinky_time && node blinky-serial-mcp/dist/index.js"
      ],
      "env": {}
    }
  }
}
