# Downloaded audio and processed data (large files)
data/audio/
data/labels/
data/processed/
data/processed-deep/
data/processed-deep-v2/
data/beat_sync/*.npy

# Calibration captures and generated audio (large, reproducible via calibrate_mic.py)
data/calibration/**
# ...but keep distilled mic profiles (small, not reproducible without hardware)
!data/calibration/mic_profile*.npz
!data/calibration/gain_sweep*.npz

# Demucs separation byproducts (allin1 temp stems and spectrograms).
# May appear at ml-training/demix/, data/labels/demix/, or other locations
# depending on --output-dir / --demix-dir settings.
**/demix/
**/spec/

# Training outputs
outputs/

