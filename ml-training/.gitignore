__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environment
venv/
venv311/
.venv/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

