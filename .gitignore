# TFLite model binaries (the .h C header is tracked, the binary is not)
*.tflite

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
**/venv/

# ML training artifacts (large, regenerated)
ml-training/data/processed/
ml-training/data/mel_cache/
ml-training/data/archive/
ml-training/outputs/*/checkpoints/

# Synthetic corpora (deterministic, regenerate via analysis/generate_tonal_corpus.py)
blinky-test-player/music/synthetic_tonals/
blinky-test-player/music/synthetic_tonals_*/

# Held-out EDM corpus (symlinks into /mnt/storage, regenerate via setup_holdout_corpus.py)
blinky-test-player/music/edm_holdout/

# CMake build directories for native harnesses (regenerated by run_parity_test.py)
tests/parity/build/
# Parity temp files (binary mags + harness CSVs)
ml-training/outputs/parity/

# Compiled binaries (prevent accidental venv/library commits)
*.so
*.dylib
*.dll
*.whl
*.tar.gz
*.zip
*.onnx
*.pt
*.pth

# Node
node_modules/
dist/

# blinky-console build output (Vite emits here for blinky-server to serve)
blinky-server/web/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
